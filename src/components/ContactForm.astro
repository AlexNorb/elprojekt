---
import PaperClipIcon from "./icons/PaperClipIcon.astro";
---

<form id="el-contact-form-element" class="space-y-6">
    <div>
        <label
            for="serviceType"
            class="block text-sm font-medium text-slate-700 font-display mb-1"
        >
            Ärende
        </label>
        <select
            id="serviceType"
            name="serviceType"
            class="block w-full rounded-md border-gray-300 bg-slate-50 border p-3 focus:border-elblue focus:ring-elblue sm:text-sm outline-none transition-all"
        >
            <option>Allmänt</option>
            <option>Offertförfrågan</option>
            <option>Service & Felsökning</option>
            <option>Laddbox</option>
            <option>Solceller</option>
        </select>
    </div>

    <div>
        <label
            for="name"
            class="block text-sm font-medium text-slate-700 font-display mb-1"
        >
            Namn
        </label>
        <input
            type="text"
            name="name"
            id="name"
            required
            class="block w-full rounded-md border-gray-300 bg-slate-50 border p-3 focus:border-elblue focus:ring-elblue sm:text-sm outline-none transition-all"
            placeholder="Förnamn Efternamn"
        />
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
            <label
                for="email"
                class="block text-sm font-medium text-slate-700 font-display mb-1"
            >
                E-post
            </label>
            <input
                type="email"
                name="email"
                id="email"
                class="block w-full rounded-md border-gray-300 bg-slate-50 border p-3 focus:border-elblue focus:ring-elblue sm:text-sm outline-none transition-all"
                placeholder="din@email.se"
            />
        </div>
        <div>
            <label
                for="phone"
                class="block text-sm font-medium text-slate-700 font-display mb-1"
            >
                Telefon
            </label>
            <input
                type="tel"
                name="phone"
                id="phone"
                class="block w-full rounded-md border-gray-300 bg-slate-50 border p-3 focus:border-elblue focus:ring-elblue sm:text-sm outline-none transition-all"
                placeholder="070-123 45 67"
            />
        </div>
    </div>

    <div>
        <label
            for="message"
            class="block text-sm font-medium text-slate-700 font-display mb-1"
        >
            Meddelande
        </label>
        <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="block w-full rounded-md border-gray-300 bg-slate-50 border p-3 focus:border-elblue focus:ring-elblue sm:text-sm outline-none transition-all"
            placeholder="Beskriv vad du behöver hjälp med..."></textarea>
    </div>

    <!-- File Upload Section -->
    <div class="flex flex-col gap-4">
        <label
            for="file-upload"
            class="flex items-center justify-center w-full px-4 py-3 border border-slate-300 border-dashed rounded-md shadow-sm text-sm font-medium text-slate-600 bg-slate-50 hover:bg-slate-100 cursor-pointer transition-colors"
        >
            <PaperClipIcon className="w-5 h-5 mr-2 text-slate-400" />
            <span>Bifoga bild eller dokument</span>
            <input
                id="file-upload"
                name="file-upload"
                type="file"
                multiple
                accept="image/*,.pdf,.doc,.docx,.xls,.xlsx"
                class="sr-only"
            />
        </label>

        <!-- Rendered Uploads Container -->
        <ul
            id="file-list"
            class="grid grid-cols-2 sm:grid-cols-3 gap-4 empty:hidden"
        >
        </ul>
    </div>

    <!-- SVG Templates for JS Rendering -->
    <template id="icon-trash">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <polyline points="3 6 5 6 21 6"></polyline>
            <path
                d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"
            ></path>
            <line x1="10" y1="11" x2="10" y2="17"></line><line
                x1="14"
                y1="11"
                x2="14"
                y2="17"></line>
        </svg>
    </template>
    <template id="icon-doc">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8 text-slate-400 mb-2"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
            ></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
            <polyline points="10 9 9 9 8 9"></polyline>
        </svg>
    </template>

    <div>
        <button
            type="submit"
            class="w-full flex justify-center py-4 px-6 border border-transparent rounded-md shadow-sm text-base font-bold text-white bg-elorange hover:bg-elorange-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-elorange transition-all duration-200 transform hover:-translate-y-1 font-display uppercase tracking-wider"
        >
            Skicka Förfrågan
        </button>
    </div>
</form>

<!-- Success Message (Hidden by default) -->
<div
    id="success-message"
    class="hidden flex-col items-center justify-center text-center py-12 px-4 space-y-4"
>
    <div
        class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-2"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8 text-green-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
        </svg>
    </div>
    <h3 class="text-2xl font-bold text-slate-800 font-display">
        Tack för din förfrågan!
    </h3>
    <p class="text-slate-600 max-w-sm">
        Vi har tagit emot ditt meddelande och återkommer till dig så snart vi
        kan. Ha en fortsatt fin dag!
    </p>
    <button
        type="button"
        id="reset-form-btn"
        class="mt-6 text-sm text-elblue hover:text-blue-800 font-medium transition-colors"
    >
        Skicka ett nytt meddelande
    </button>
</div>

<script>
    document.addEventListener("astro:page-load", () => {
        const form = document.getElementById("el-contact-form-element");
        if (form) {
            const emailInput = form.querySelector(
                'input[name="email"]',
            ) as HTMLInputElement;
            const phoneInput = form.querySelector(
                'input[name="phone"]',
            ) as HTMLInputElement;
            const submitButton = form.querySelector(
                'button[type="submit"]',
            ) as HTMLButtonElement;
            const fileInput = form.querySelector(
                'input[name="file-upload"]',
            ) as HTMLInputElement;
            const fileListContainer = document.getElementById(
                "file-list",
            ) as HTMLUListElement;

            const successMessage = document.getElementById("success-message");
            const resetFormBtn = document.getElementById("reset-form-btn");

            // Templates
            const trashIconTpl = document.getElementById(
                "icon-trash",
            ) as HTMLTemplateElement;
            const docIconTpl = document.getElementById(
                "icon-doc",
            ) as HTMLTemplateElement;

            const MAX_TOTAL_SIZE = 20 * 1024 * 1024; // 20 MB

            // Vår State management för filer i minnet
            let sessionFiles: Array<{
                id: string; // Unikt snabbt ID
                originalName: string;
                isImage: boolean;
                base64Data: string; // Utan "data:...base64,"
                sizeBytes: number;
            }> = [];

            const validateGroup = () => {
                if (!phoneInput.value && !emailInput.value) {
                    emailInput.setCustomValidity(
                        "Du måste fylla i antingen e-post eller telefonnummer.",
                    );
                } else {
                    emailInput.setCustomValidity("");
                }
            };

            emailInput.addEventListener("input", validateGroup);
            phoneInput.addEventListener("input", validateGroup);
            validateGroup();

            // Verktyg: Formatera storlek snyggt
            const formatBytes = (bytes: number) => {
                if (bytes === 0) return "0 Bytes";
                const k = 1024;
                const sizes = ["Bytes", "KB", "MB", "GB"];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return (
                    parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + " " + sizes[i]
                );
            };

            // UI: Rita ut valda filer
            const renderFileList = () => {
                fileListContainer.innerHTML = "";

                sessionFiles.forEach((fileObj) => {
                    const li = document.createElement("li");
                    li.className =
                        "relative group flex flex-col items-center justify-center p-3 border border-slate-200 rounded-lg bg-white overflow-hidden shadow-sm";

                    // Media eller Ikon
                    if (fileObj.isImage) {
                        const img = document.createElement("img");
                        // Vi måste lägga till mime-headern igen bara för att visa bilden i UI:t
                        img.src = `data:image/jpeg;base64,${fileObj.base64Data}`;
                        img.className =
                            "w-full h-24 object-cover rounded shadow-inner mb-2";
                        li.appendChild(img);
                    } else {
                        const iconClone = docIconTpl.content.cloneNode(true);
                        li.appendChild(iconClone);

                        const nameSpan = document.createElement("span");
                        nameSpan.className =
                            "text-xs font-semibold text-slate-700 truncate w-full text-center mb-1";
                        nameSpan.title = fileObj.originalName;
                        nameSpan.innerText = fileObj.originalName;
                        li.appendChild(nameSpan);
                    }

                    // Storlek (Komprimerad / Faktisk)
                    const sizeSpan = document.createElement("span");
                    sizeSpan.className =
                        "text-[10px] text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full";
                    sizeSpan.innerText = formatBytes(fileObj.sizeBytes);
                    li.appendChild(sizeSpan);

                    // Papperskorg Knapp (Visas vid hover på Desktop, alltid övre kant på mobil)
                    const removeBtn = document.createElement("button");
                    removeBtn.type = "button";
                    removeBtn.className =
                        "absolute top-1 right-1 p-1 bg-white/90 text-red-500 rounded-full opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity shadow-sm hover:bg-red-50";
                    const trashClone = trashIconTpl.content.cloneNode(true);
                    removeBtn.appendChild(trashClone);

                    removeBtn.addEventListener("click", () => {
                        sessionFiles = sessionFiles.filter(
                            (f) => f.id !== fileObj.id,
                        );
                        renderFileList();
                    });

                    li.appendChild(removeBtn);
                    fileListContainer.appendChild(li);
                });
            };

            // Hjälpfunktion för att komprimera bilder med Canvas
            const compressImage = (
                file: File,
                maxWidth = 1920,
                quality = 0.8,
            ): Promise<string> => {
                return new Promise((resolve, reject) => {
                    const img = new Image();
                    img.src = URL.createObjectURL(file);
                    img.onload = () => {
                        URL.revokeObjectURL(img.src);
                        let width = img.width;
                        let height = img.height;

                        if (width > maxWidth) {
                            height = Math.round((height * maxWidth) / width);
                            width = maxWidth;
                        }

                        const canvas = document.createElement("canvas");
                        canvas.width = width;
                        canvas.height = height;
                        const ctx = canvas.getContext("2d");
                        if (!ctx)
                            return reject(
                                new Error("Could not get canvas context"),
                            );

                        ctx.drawImage(img, 0, 0, width, height);
                        const dataUrl = canvas.toDataURL("image/jpeg", quality);
                        const base64Content = dataUrl.split(",")[1];
                        resolve(base64Content);
                    };
                    img.onerror = (error) => reject(error);
                });
            };

            // Hjälpfunktion för att läsa andra filer som Base64
            const readFileAsBase64 = (file: File): Promise<string> => {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = () => {
                        const result = reader.result as string;
                        const base64Content = result.split(",")[1];
                        resolve(base64Content);
                    };
                    reader.onerror = (error) => reject(error);
                    reader.readAsDataURL(file);
                });
            };

            // Omedelbar komprimering och processering vid fil-val (onChange)
            fileInput.addEventListener("change", async (e) => {
                const files = (e.target as HTMLInputElement).files;
                if (!files || files.length === 0) return;

                // Användare valde filer -- byt text på knappen tillfälligt för feedback under processing
                const labelSpan =
                    fileInput.previousElementSibling as HTMLSpanElement;
                const originalLabelText = labelSpan.innerText;
                labelSpan.innerText = "Laddar och komprimerar...";

                // Vi blockerar submit-knappen tillfälligt under tiden vi bearbetar
                const originalSubmitText = submitButton.innerText;
                submitButton.disabled = true;
                submitButton.innerText = "Bearbetar Filer...";
                submitButton.classList.add("opacity-70", "cursor-not-allowed");

                let currentTotalSize = sessionFiles.reduce(
                    (acc, f) => acc + f.sizeBytes,
                    0,
                );

                for (let i = 0; i < files.length; i++) {
                    const file = files[i];

                    // Enkel filtyp-koll
                    const isImage = file.type.startsWith("image/");
                    const isValidDoc = file.name.match(
                        /\.(pdf|doc|docx|xls|xlsx)$/i,
                    );

                    if (!isImage && !isValidDoc) {
                        alert(
                            `Ogiltig filtyp: ${file.name}. Vi stödjer bara bilder och vanliga dokument (PDF, Word, Excel).`,
                        );
                        continue; // Skippa denna fil
                    }

                    let base64Content = "";
                    let finalSizeBytes = 0;

                    try {
                        if (isImage) {
                            base64Content = await compressImage(file);
                            // Räkna ut ungefärlig storlek på base64 strängen i bytes (varje base64 char = 3/4 byte)
                            finalSizeBytes = Math.round(
                                (base64Content.length * 3) / 4,
                            );
                        } else {
                            base64Content = await readFileAsBase64(file);
                            finalSizeBytes = file.size; // Orginalstorlek för okomprimerade dokument
                        }

                        // Kolla mot MAX_TOTAL_SIZE
                        if (currentTotalSize + finalSizeBytes > MAX_TOTAL_SIZE) {
                            alert(
                                `Filen ${file.name} fick inte plats! Max storlek på uppladdningar (efter ev. komprimering) är 20 MB.`,
                            );
                            continue;
                        }

                        currentTotalSize += finalSizeBytes;
                        sessionFiles.push({
                            id: Math.random().toString(36).substr(2, 9),
                            originalName: file.name,
                            isImage,
                            base64Data: base64Content,
                            sizeBytes: finalSizeBytes,
                        });
                    } catch (err) {
                        console.error("Kunde inte läsa filen", file.name, err);
                    }
                }

                // Rensa inputen så att man kan välja exakt samma fil igen (change trigger).
                fileInput.value = "";
                labelSpan.innerText = originalLabelText;

                // Återställ submit-knappen
                submitButton.disabled = false;
                submitButton.innerText = originalSubmitText;
                submitButton.classList.remove("opacity-70", "cursor-not-allowed");

                renderFileList();
            });

            // Sändning av formuläret
            form.addEventListener("submit", async (e) => {
                e.preventDefault();

                const originalButtonText = submitButton.innerText;
                submitButton.disabled = true;
                submitButton.innerText = "Skickar...";
                submitButton.classList.add("opacity-70", "cursor-not-allowed");

                try {
                    const formData = new FormData(e.target as HTMLFormElement);
                    const data = Object.fromEntries(formData.entries());

                    const payload: any = {
                        name: data.name,
                        email: data.email,
                        phone: data.phone,
                        serviceType: data.serviceType,
                        message: data.message,
                        attachments: sessionFiles.map((f) => ({
                            filename: f.originalName,
                            content: f.base64Data,
                        })), // Redan klara i minnet!
                    };

                    const response = await fetch(
                        "https://broad-truth-b482-resend-form-handler.allecc.workers.dev",
                        {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify(payload),
                        },
                    );

                    if (response.ok) {
                        // Istället för alert: Dölj formulär, visa success
                        form.style.display = "none";
                        if (successMessage) {
                            successMessage.classList.remove("hidden");
                            successMessage.classList.add("flex");
                            // Scrolla success-meddelandet till en bra position
                            const navbarHeight = 80; // En uppskattning ifall du har fixed navbar
                            const topPosition =
                                successMessage.getBoundingClientRect().top +
                                window.scrollY -
                                navbarHeight -
                                20;
                            window.scrollTo({
                                top: topPosition,
                                behavior: "smooth",
                            });
                        }

                        (e.target as HTMLFormElement).reset();
                        // Rensa UI och state
                        sessionFiles = [];
                        renderFileList();
                    } else {
                        alert(
                            "Ett fel uppstod när meddelandet skulle skickas. Vänligen försök igen senare eller maila oss direkt.",
                        );
                    }
                } catch (error: any) {
                    console.error("Nätverksfel eller CORS-problem:", error);
                    alert(
                        "Kunde inte kontakta servern. Vänligen försök igen senare.",
                    );
                } finally {
                    submitButton.disabled = false;
                    submitButton.innerText = originalButtonText;
                    submitButton.classList.remove(
                        "opacity-70",
                        "cursor-not-allowed",
                    );
                }
            });

            // Hantera reset ("Skicka nytt meddelande")
            if (resetFormBtn) {
                resetFormBtn.addEventListener("click", () => {
                    if (successMessage) {
                        successMessage.classList.add("hidden");
                        successMessage.classList.remove("flex");
                    }
                    form.style.display = "block"; // eller flex om det är orginal display. form har ingen men css class="space-y-6"
                });
            }
        }
    });
</script>
